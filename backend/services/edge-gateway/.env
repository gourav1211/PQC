# H2A-PQC Edge Gateway - Local Development Environment
# =====================================================

# MongoDB connection with authentication
MONGODB_URI=mongodb://h2a_admin:h2a_secret@localhost:27017/h2a_pqc?authSource=admin

# Server configuration
NODE_ENV=development
PORT=4000
MODE=h2a

# Aggregation settings
AGGREGATION_BATCH_SIZE=50
AGGREGATION_TIMEOUT_MS=5000

# Logging
LOG_LEVEL=info
